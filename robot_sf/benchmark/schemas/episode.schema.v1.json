{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.com/robot-sf/episode.schema.v1.json",
    "title": "RobotSF Benchmark Episode (v1)",
    "type": "object",
    "additionalProperties": true,
    "required": [
        "version",
        "episode_id",
        "scenario_id",
        "seed",
        "metrics",
        "termination_reason",
        "outcome",
        "integrity"
    ],
    "allOf": [
        {
            "if": {
                "properties": {
                    "outcome": {
                        "properties": {
                            "collision_event": {
                                "const": true
                            }
                        },
                        "required": [
                            "collision_event"
                        ]
                    }
                },
                "required": [
                    "outcome"
                ]
            },
            "then": {
                "properties": {
                    "metrics": {
                        "properties": {
                            "collisions": {
                                "type": [
                                    "number",
                                    "integer"
                                ],
                                "exclusiveMinimum": 0
                            }
                        }
                    }
                }
            }
        },
        {
            "if": {
                "properties": {
                    "outcome": {
                        "properties": {
                            "collision_event": {
                                "const": false
                            }
                        },
                        "required": [
                            "collision_event"
                        ]
                    }
                },
                "required": [
                    "outcome"
                ]
            },
            "then": {
                "properties": {
                    "metrics": {
                        "properties": {
                            "collisions": {
                                "type": [
                                    "number",
                                    "integer"
                                ],
                                "maximum": 0
                            }
                        }
                    }
                }
            }
        }
    ],
    "properties": {
        "version": {
            "const": "v1"
        },
        "episode_id": {
            "type": "string",
            "minLength": 1
        },
        "scenario_id": {
            "type": "string",
            "minLength": 1
        },
        "scenario_params": {
            "type": "object"
        },
        "seed": {
            "type": "integer"
        },
        "horizon": {
            "type": "integer",
            "minimum": 1
        },
        "algo": {
            "type": "string"
        },
        "observation_mode": {
            "type": "string",
            "description": "Active planner observation-mode contract for this episode."
        },
        "algorithm_metadata": {
            "type": "object",
            "description": "Metadata about the algorithm/policy used (name, config, status).",
            "properties": {
                "algorithm": {
                    "type": "string"
                },
                "canonical_algorithm": {
                    "type": "string"
                },
                "status": {
                    "type": "string",
                    "enum": [
                        "ok",
                        "fallback",
                        "error",
                        "placeholder"
                    ]
                },
                "fallback_reason": {
                    "type": "string"
                },
                "baseline_category": {
                    "type": "string",
                    "enum": [
                        "diagnostic",
                        "classical",
                        "learning",
                        "unknown"
                    ]
                },
                "policy_semantics": {
                    "type": "string"
                },
                "observation_spec": {
                    "type": "object",
                    "properties": {
                        "default_mode": {
                            "type": "string"
                        },
                        "active_mode": {
                            "type": "string"
                        },
                        "supported_modes": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "inputs": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "override_applied": {
                            "type": "boolean"
                        },
                        "notes": {
                            "type": "string"
                        }
                    },
                    "additionalProperties": true
                },
                "config": {
                    "type": "object"
                },
                "config_hash": {
                    "type": "string"
                },
                "stochastic_reference": {
                    "type": "boolean"
                },
                "distinct_from_goal_baseline": {
                    "type": "boolean"
                },
                "planner_kinematics": {
                    "type": "object",
                    "properties": {
                        "robot_kinematics": {
                            "type": "string"
                        },
                        "planner_command_space": {
                            "type": "string"
                        },
                        "supports_native_commands": {
                            "type": "boolean"
                        },
                        "supports_adapter_commands": {
                            "type": "boolean"
                        },
                        "execution_mode": {
                            "type": "string",
                            "enum": [
                                "native",
                                "adapter",
                                "mixed",
                                "unknown"
                            ]
                        },
                        "adapter_name": {
                            "type": "string"
                        },
                        "adapter_active": {
                            "type": "boolean"
                        },
                        "scenario_kinematics": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    },
                    "additionalProperties": true
                },
                "adapter_impact": {
                    "type": "object",
                    "properties": {
                        "requested": {
                            "type": "boolean"
                        },
                        "native_steps": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "adapted_steps": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "status": {
                            "type": "string"
                        },
                        "execution_mode": {
                            "type": "string",
                            "enum": [
                                "native",
                                "adapter",
                                "mixed",
                                "unknown"
                            ]
                        },
                        "adapter_fraction": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1.0
                        }
                    },
                    "additionalProperties": true
                },
                "kinematics_feasibility": {
                    "type": "object",
                    "properties": {
                        "commands_evaluated": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "infeasible_native_count": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "projected_count": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "projection_rate": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1.0
                        },
                        "infeasible_rate": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1.0
                        },
                        "mean_abs_delta_linear": {
                            "type": "number",
                            "minimum": 0
                        },
                        "mean_abs_delta_angular": {
                            "type": "number",
                            "minimum": 0
                        },
                        "max_abs_delta_linear": {
                            "type": "number",
                            "minimum": 0
                        },
                        "max_abs_delta_angular": {
                            "type": "number",
                            "minimum": 0
                        }
                    },
                    "additionalProperties": true
                }
            },
            "additionalProperties": true
        },
        "metric_parameters": {
            "type": "object",
            "description": "Metric threshold profile and signature used for report reproducibility.",
            "properties": {
                "threshold_signature": {
                    "type": "string"
                },
                "threshold_profile": {
                    "type": "object",
                    "properties": {
                        "profile_id": {
                            "type": "string"
                        },
                        "collision_distance_m": {
                            "type": "number"
                        },
                        "near_miss_distance_m": {
                            "type": "number"
                        },
                        "comfort_force_threshold": {
                            "type": "number"
                        }
                    },
                    "required": [
                        "profile_id",
                        "collision_distance_m",
                        "near_miss_distance_m",
                        "comfort_force_threshold"
                    ],
                    "additionalProperties": true
                }
            },
            "required": [
                "threshold_signature",
                "threshold_profile"
            ],
            "additionalProperties": true
        },
        "metrics": {
            "type": "object",
            "minProperties": 1,
            "properties": {
                "collisions": {
                    "type": [
                        "number",
                        "integer"
                    ],
                    "minimum": 0
                },
                "collision_rate": {
                    "type": [
                        "number",
                        "integer"
                    ],
                    "minimum": 0
                },
                "pedestrian_impact": {
                    "type": "object",
                    "description": "Schema-backed pedestrian-impact metric block for opt-in near-vs-far reductions.",
                    "required": [
                        "schema_version",
                        "parameters",
                        "units",
                        "sample_counts",
                        "canonical_reductions"
                    ],
                    "properties": {
                        "schema_version": {
                            "const": "pedestrian-impact.v1"
                        },
                        "parameters": {
                            "type": "object",
                            "properties": {
                                "near_radius_m": {
                                    "type": "number",
                                    "exclusiveMinimum": 0
                                },
                                "window_steps": {
                                    "type": "integer",
                                    "minimum": 1
                                }
                            },
                            "required": [
                                "near_radius_m",
                                "window_steps"
                            ],
                            "additionalProperties": true
                        },
                        "units": {
                            "type": "object",
                            "properties": {
                                "accel": {
                                    "const": "m/s^2"
                                },
                                "turn_rate": {
                                    "const": "rad/s"
                                },
                                "near_radius": {
                                    "const": "m"
                                },
                                "sample_counts": {
                                    "const": "samples"
                                },
                                "sample_fraction": {
                                    "const": "fraction"
                                }
                            },
                            "additionalProperties": true
                        },
                        "sample_counts": {
                            "type": "object",
                            "properties": {
                                "pedestrians": {
                                    "type": "integer",
                                    "minimum": 0
                                },
                                "near_samples": {
                                    "type": "integer",
                                    "minimum": 0
                                },
                                "far_samples": {
                                    "type": "integer",
                                    "minimum": 0
                                },
                                "near_sample_frac": {
                                    "type": "number",
                                    "minimum": 0,
                                    "maximum": 1
                                }
                            },
                            "additionalProperties": true
                        },
                        "canonical_reductions": {
                            "type": "object",
                            "properties": {
                                "accel_delta_mean": {
                                    "type": "number"
                                },
                                "accel_delta_median": {
                                    "type": "number"
                                },
                                "accel_delta_valid_pedestrians": {
                                    "type": "integer",
                                    "minimum": 0
                                },
                                "turn_rate_delta_mean": {
                                    "type": "number"
                                },
                                "turn_rate_delta_median": {
                                    "type": "number"
                                },
                                "turn_rate_delta_valid_pedestrians": {
                                    "type": "integer",
                                    "minimum": 0
                                }
                            },
                            "additionalProperties": true
                        },
                        "component_means": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "number"
                            }
                        },
                        "interpretation": {
                            "type": "string"
                        }
                    },
                    "additionalProperties": true
                }
            },
            "additionalProperties": {
                "type": [
                    "number",
                    "integer",
                    "boolean",
                    "object"
                ]
            }
        },
        "termination_reason": {
            "type": "string",
            "enum": [
                "success",
                "collision",
                "terminated",
                "truncated",
                "max_steps",
                "error"
            ]
        },
        "outcome": {
            "type": "object",
            "required": [
                "route_complete",
                "collision_event",
                "timeout_event"
            ],
            "properties": {
                "route_complete": {
                    "type": "boolean"
                },
                "collision_event": {
                    "type": "boolean"
                },
                "timeout_event": {
                    "type": "boolean"
                }
            },
            "additionalProperties": false
        },
        "integrity": {
            "type": "object",
            "required": [
                "contradictions"
            ],
            "properties": {
                "contradictions": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "additionalProperties": true
        },
        "config_hash": {
            "type": "string"
        },
        "git_hash": {
            "type": "string"
        },
        "timestamps": {
            "type": "object",
            "required": [
                "start",
                "end"
            ],
            "properties": {
                "start": {
                    "type": "string",
                    "format": "date-time"
                },
                "end": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "additionalProperties": true
        },
        "timing": {
            "type": "object",
            "required": [
                "steps_per_second"
            ],
            "properties": {
                "steps_per_second": {
                    "type": "number",
                    "minimum": 0
                }
            },
            "additionalProperties": false
        },
        "notes": {
            "type": "string"
        },
        "tags": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "identity": {
            "type": "object",
            "additionalProperties": true
        },
        "observation_noise": {
            "type": "object",
            "description": "Benchmark-only planner-input observation noise profile.",
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "profile": {
                    "type": "string"
                },
                "interpretation": {
                    "type": "string"
                },
                "pose_noise_std_m": {
                    "type": "number",
                    "minimum": 0
                },
                "heading_noise_std_rad": {
                    "type": "number",
                    "minimum": 0
                },
                "lidar_dropout_prob": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "pedestrian_false_negative_prob": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                },
                "pedestrian_false_positive_prob": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                }
            },
            "additionalProperties": true
        },
        "observation_noise_hash": {
            "type": "string"
        },
        "observation_noise_stats": {
            "type": "object",
            "additionalProperties": {
                "type": "integer",
                "minimum": 0
            }
        },
        "video": {
            "type": "object",
            "description": "Optional per-episode video artifact metadata.",
            "properties": {
                "path": {
                    "type": "string"
                },
                "format": {
                    "type": "string",
                    "enum": [
                        "mp4"
                    ]
                },
                "filesize_bytes": {
                    "type": "integer",
                    "minimum": 1
                },
                "frames": {
                    "type": "integer",
                    "minimum": 0
                },
                "renderer": {
                    "type": "string",
                    "enum": [
                        "synthetic",
                        "sim-view",
                        "none"
                    ]
                },
                "notes": {
                    "type": "string"
                },
                "encode_seconds": {
                    "type": "number",
                    "minimum": 0
                },
                "overhead_ratio": {
                    "type": "number",
                    "minimum": 0
                }
            },
            "required": [
                "path",
                "format",
                "filesize_bytes",
                "frames",
                "renderer"
            ],
            "additionalProperties": true
        }
    }
}
