{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/robot-sf/generated_scenario_candidate.v1.json",
  "title": "RobotSF Generated Scenario Candidate (v1)",
  "description": "Validation contract for scenario candidates produced by heuristic, RL-adversary, or diffusion/generative-prior generators. This is not benchmark execution evidence; promotion to benchmark-strength requires passing all gates defined in docs/context/issue_2725_generator_readiness.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "candidate_id",
    "generator_family",
    "generator_run_id",
    "generator_config_ref",
    "source_scenario_ref",
    "source_split",
    "perturbations",
    "validity",
    "metrics_summary",
    "trace_lineage",
    "promotion_status"
  ],
  "properties": {
    "schema_version": {
      "const": "generated_scenario_candidate.v1"
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9_.:-]+$"
    },
    "generator_family": {
      "enum": [
        "heuristic_perturbation",
        "rl_adversary",
        "diffusion_prior",
        "generative_prior"
      ]
    },
    "generator_run_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9_.:-]+$"
    },
    "generator_config_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "config_path",
        "config_hash"
      ],
      "properties": {
        "config_path": {
          "type": "string",
          "minLength": 1
        },
        "config_hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "adversary_checkpoint_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_path",
        "checkpoint_hash"
      ],
      "properties": {
        "checkpoint_path": {
          "type": "string",
          "minLength": 1
        },
        "checkpoint_hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "model_checkpoint_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_path",
        "checkpoint_hash"
      ],
      "properties": {
        "checkpoint_path": {
          "type": "string",
          "minLength": 1
        },
        "checkpoint_hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sample_params": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "temperature": {
          "type": "number",
          "minimum": 0
        },
        "guidance_scale": {
          "type": "number",
          "minimum": 0
        },
        "num_samples": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "source_scenario_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_name",
        "config_path",
        "config_hash"
      ],
      "properties": {
        "scenario_name": {
          "type": "string",
          "minLength": 1
        },
        "config_path": {
          "type": "string",
          "minLength": 1
        },
        "config_hash": {
          "type": "string",
          "minLength": 1
        },
        "map_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_split": {
      "enum": [
        "train",
        "validation",
        "test"
      ]
    },
    "perturbations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/perturbation"
      }
    },
    "validity": {
      "$ref": "#/$defs/validity"
    },
    "metrics_summary": {
      "$ref": "#/$defs/metrics_summary"
    },
    "trace_lineage": {
      "$ref": "#/$defs/trace_lineage"
    },
    "promotion_status": {
      "enum": [
        "not_promoted",
        "promoted"
      ],
      "default": "not_promoted"
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "generator_family": {
            "const": "rl_adversary"
          }
        },
        "required": ["generator_family"]
      },
      "then": {
        "required": ["adversary_checkpoint_ref"]
      }
    },
    {
      "if": {
        "properties": {
          "generator_family": {
            "enum": ["diffusion_prior", "generative_prior"]
          }
        },
        "required": ["generator_family"]
      },
      "then": {
        "required": ["model_checkpoint_ref", "sample_params"]
      }
    },
    {
      "if": {
        "properties": {
          "promotion_status": {
            "const": "promoted"
          }
        },
        "required": ["promotion_status"]
      },
      "then": {
        "properties": {
          "validity": {
            "required": [
              "preflight_passed",
              "scenario_certified",
              "map_exists",
              "spawn_collision_free",
              "goal_reachable"
            ],
            "properties": {
              "preflight_passed": {"const": true},
              "scenario_certified": {"const": true},
              "map_exists": {"const": true},
              "spawn_collision_free": {"const": true},
              "goal_reachable": {"const": true}
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "perturbation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "parameters"
      ],
      "properties": {
        "family": {
          "enum": [
            "robot_route_offset",
            "pedestrian_route_offset",
            "single_pedestrian_speed_offset",
            "single_pedestrian_start_delay_offset",
            "single_pedestrian_wait_duration_offset",
            "single_pedestrian_trajectory_waypoint_offset",
            "pedestrian_density_offset",
            "noop"
          ]
        },
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dx_m": {
              "type": "number"
            },
            "dy_m": {
              "type": "number"
            },
            "max_magnitude_m": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "spawn_id": {
              "type": "integer",
              "minimum": 0
            },
            "goal_id": {
              "type": "integer",
              "minimum": 0
            },
            "waypoint_selector": {
              "const": "all"
            },
            "dt_s": {
              "type": "number"
            },
            "max_abs_dt_s": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "pedestrian_id": {
              "type": "string",
              "minLength": 1
            },
            "pedestrian_selector": {
              "const": "all"
            },
            "speed_delta_m_s": {
              "type": "number"
            },
            "max_abs_speed_delta_m_s": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "max_speed_m_s": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "wait_delta_s": {
              "type": "number"
            },
            "max_abs_wait_delta_s": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "density_delta": {
              "type": "number"
            },
            "max_abs_density_delta": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "max_ped_density": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          }
        },
        "rationale": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "family": {
                "enum": [
                  "robot_route_offset",
                  "pedestrian_route_offset"
                ]
              }
            },
            "required": ["family"]
          },
          "then": {
            "properties": {
              "parameters": {
                "required": ["dx_m", "dy_m", "max_magnitude_m"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "family": {
                "const": "single_pedestrian_speed_offset"
              }
            },
            "required": ["family"]
          },
          "then": {
            "properties": {
              "parameters": {
                "required": ["speed_delta_m_s", "max_abs_speed_delta_m_s"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "family": {
                "const": "single_pedestrian_start_delay_offset"
              }
            },
            "required": ["family"]
          },
          "then": {
            "properties": {
              "parameters": {
                "required": ["dt_s", "max_abs_dt_s"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "family": {
                "const": "single_pedestrian_wait_duration_offset"
              }
            },
            "required": ["family"]
          },
          "then": {
            "properties": {
              "parameters": {
                "required": ["wait_delta_s", "max_abs_wait_delta_s"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "family": {
                "const": "pedestrian_density_offset"
              }
            },
            "required": ["family"]
          },
          "then": {
            "properties": {
              "parameters": {
                "required": ["density_delta", "max_abs_density_delta"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "family": {
                "const": "noop"
              }
            },
            "required": ["family"]
          },
          "then": {
            "not": {
              "required": ["parameters"],
              "properties": {
                "parameters": {
                  "minProperties": 1
                }
              }
            }
          }
        }
      ]
    },
    "validity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preflight_passed",
        "scenario_certified",
        "map_exists"
      ],
      "properties": {
        "preflight_passed": {
          "type": "boolean"
        },
        "scenario_certified": {
          "type": "boolean"
        },
        "map_exists": {
          "type": "boolean"
        },
        "spawn_collision_free": {
          "type": "boolean"
        },
        "goal_reachable": {
          "type": "boolean"
        },
        "rejection_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "metrics_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "diversity"
      ],
      "properties": {
        "severity": {
          "$ref": "#/$defs/severity_metrics"
        },
        "diversity": {
          "$ref": "#/$defs/diversity_metrics"
        }
      }
    },
    "severity_metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ttc_min_s": {
          "type": ["number", "null"]
        },
        "min_clearance_m": {
          "type": ["number", "null"]
        },
        "comfort_force_max_N": {
          "type": ["number", "null"]
        },
        "near_miss_count": {
          "type": ["integer", "null"]
        },
        "collision_count": {
          "type": ["integer", "null"]
        },
        "timeout_risk": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "objective_value": {
          "type": ["number", "null"]
        }
      }
    },
    "diversity_metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "param_distance_min_m": {
          "type": ["number", "null"]
        },
        "param_distance_mean_m": {
          "type": ["number", "null"]
        },
        "unique_scenario_families": {
          "type": ["integer", "null"]
        },
        "coverage_fraction": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "dedup_rate": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "trace_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seed",
        "generated_at_utc",
        "git_hash",
        "provenance"
      ],
      "properties": {
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "generated_at_utc": {
          "type": "string",
          "minLength": 1
        },
        "git_hash": {
          "type": "string",
          "minLength": 1
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_issue"
          ],
          "properties": {
            "source_issue": {
              "type": "string",
              "minLength": 1
            },
            "model_version": {
              "type": "string"
            },
            "checkpoint_path": {
              "type": "string"
            },
            "training_run_id": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
