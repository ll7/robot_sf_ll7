{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robot-sf.local/schemas/amv_actuation_latency_measurement_manifest.v1.json",
  "title": "Robot SF AMV Actuation Latency & Rider-Coupling Measurement Manifest v1",
  "description": "Metadata-only intake manifest describing how an autonomous micromobility vehicle (AMV) actuation-latency and rider-coupling MEASUREMENT campaign is (or would be) collected: declared sensor channels, sampling rate, time synchronization, provenance, and the synthetic-vs-measured separation. It declares the measurement PLAN and the proposed AMV-profile fields it will populate. It carries NO measured values and makes NO calibrated-actuation claim until measurement_status is 'measured' with accepted provenance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "measurement_status",
    "description",
    "synchronization",
    "sensor_channels",
    "proposed_profile_fields",
    "synthetic_separation"
  ],
  "properties": {
    "schema_version": {
      "const": "amv_actuation_latency_measurement_manifest.v1"
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "measurement_status": {
      "description": "Lifecycle state of the measurement intake. 'blocked-external-input': a valid plan awaiting external data; 'synthetic-only': placeholder assumptions, never measured; 'measured': real command-response data has been collected and provenance accepted.",
      "enum": ["blocked-external-input", "synthetic-only", "measured"]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "synchronization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "reference_clock", "max_skew_ms"],
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "reference_clock": {
          "type": "string",
          "minLength": 1
        },
        "max_skew_ms": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "sensor_channels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["quantity", "sensor", "units", "sampling_rate_hz"],
        "properties": {
          "quantity": {
            "type": "string",
            "minLength": 1
          },
          "sensor": {
            "type": "string",
            "minLength": 1
          },
          "units": {
            "type": "string",
            "minLength": 1
          },
          "sampling_rate_hz": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    },
    "proposed_profile_fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "parameter_class", "units", "value_status"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "parameter_class": {
            "enum": ["latency", "rider_coupling"]
          },
          "units": {
            "type": "string",
            "minLength": 1
          },
          "value_status": {
            "enum": ["synthetic-placeholder", "pending", "measured"]
          }
        }
      }
    },
    "synthetic_separation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["separation"],
      "properties": {
        "separation": {
          "enum": ["enforced", "not-enforced"]
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source_id": {
          "type": "string"
        },
        "source_uri": {
          "type": "string"
        },
        "source_type": {
          "type": "string"
        },
        "measurement_date": {
          "type": "string"
        },
        "units": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  }
}
