{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robot-sf.local/schemas/failure_mechanism_taxonomy_crosswalk.schema.v1.json",
  "title": "Failure Mechanism Taxonomy Crosswalk v1",
  "description": "Diagnostic crosswalk from classifier labels to explicitly unavailable canonical taxonomy attribution. The classifier operates on paired aggregate metrics without trace or provenance sidecar inputs, so every entry remains unknown and must not be mistaken for causal proof.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "crosswalk_schema_version",
    "crosswalk_source",
    "entries"
  ],
  "properties": {
    "crosswalk_schema_version": {
      "const": "failure_mechanism_taxonomy_crosswalk.v1"
    },
    "crosswalk_source": {
      "const": "failure_mechanism_classifier.v1"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "row_index",
          "classifier_label",
          "taxonomy_label",
          "taxonomy_confidence",
          "evidence_mode",
          "evidence_uri",
          "unavailable_reason",
          "caveat"
        ],
        "properties": {
          "row_index": {
            "type": "integer",
            "minimum": 0
          },
          "classifier_label": {
            "enum": [
              "time_budget_clean_relief",
              "exposure_enabled_completion",
              "safety_regressed_long_horizon",
              "persistent_low_progress_timeout",
              "scenario_contract_blocker",
              "unsupported_wait_then_go_hypothesis",
              "collision",
              "near_miss",
              "timeout_without_progress",
              "unavailable"
            ]
          },
          "taxonomy_label": {
            "const": "unknown"
          },
          "taxonomy_confidence": {
            "const": "unknown"
          },
          "evidence_mode": {
            "const": "unknown"
          },
          "evidence_uri": {
            "const": ""
          },
          "unavailable_reason": {
            "const": "not_derivable_missing_trace_or_provenance"
          },
          "caveat": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
