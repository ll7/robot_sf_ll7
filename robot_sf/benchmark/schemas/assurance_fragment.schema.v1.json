{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/robot-sf/assurance_fragment.schema.v1.json",
  "title": "RobotSF Assurance Fragment (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "campaign_id",
    "generated_at_utc",
    "nodes"
  ],
  "properties": {
    "schema_version": {
      "const": "assurance_fragment.v1"
    },
    "campaign_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "text"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "goal",
              "strategy",
              "assumption",
              "context",
              "solution"
            ]
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "children": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
