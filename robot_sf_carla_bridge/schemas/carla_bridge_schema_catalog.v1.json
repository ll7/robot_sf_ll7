{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robot-sf.local/schemas/carla_bridge_schema_catalog.v1.json",
  "title": "Robot-SF CARLA Bridge Schema Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "schemas"],
  "properties": {
    "schema_version": {
      "const": "carla-bridge-schema-catalog.v1"
    },
    "schemas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "loader", "schema_version"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "loader": {
            "type": "string",
            "minLength": 1
          },
          "schema_version": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
